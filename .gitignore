# ------------------------------------------------------------------
# Report-related files: the Python renderer, the generated .tex
# source, and the compiled PDF are all excluded from the public repo.
# Readers who want the report can download it from the release page
# or rebuild it locally with build_report.py.
# ------------------------------------------------------------------
codes/build_report.py
MNIST_From_Scratch_Report_Leyan_Huang.tex
*.pdf

# ------------------------------------------------------------------
# Training artefacts
#   We keep the JSON summaries (tiny, needed to rebuild the report)
#   and drop the heavy stuff (model checkpoints, per-iter histories,
#   generated PNG figures -- all regenerable from the checkpoints).
# ------------------------------------------------------------------
codes/results/full/models/
codes/results/full/history/
codes/results/full/figs/
codes/results_*/
codes/best_models/
codes/saved_models/
codes/idx.pickle
*.pickle

# ------------------------------------------------------------------
# Legacy / exploratory files (pre-refactor, not used by the pipeline)
# ------------------------------------------------------------------
codes/advanced_analysis.py
codes/hyperparameter_search.py
codes/optional_directions.py
codes/run_experiments.py
codes/test_model.py
codes/weight_visualization.py
codes/dataset_explore.ipynb
codes/draw_tools/
codes/mlp_sgd_multistep_curves.png
codes/README.md
results_full_*.log
REPORT*.md
PROJECT_AUDIT.md
SUBMISSION_CHECKLIST.md

# ------------------------------------------------------------------
# Reference / third-party material (kept locally for convenience,
# not part of the submission repo)
# ------------------------------------------------------------------
*_extracted.txt

# ------------------------------------------------------------------
# Explicit re-includes: keep MNIST in-repo so Colab users can train
# without needing network access.
# ------------------------------------------------------------------
!codes/dataset/
!codes/dataset/MNIST/
!codes/dataset/MNIST/*.gz
!codes/dataset/MNIST/README.md
